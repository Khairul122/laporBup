# ============================================================
# TEMPLATE ENVIRONMENT — Salin ke .env, .env.staging, atau
# .env.production dan isi nilai yang sesuai.
# JANGAN commit fail .env* sebenar ke Git.
# ============================================================

# Environment: local | staging | production
APP_ENV=local

# Debug mode (true/false) — auto false bila APP_ENV=production
APP_DEBUG=true

# Database
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=silapga_web

# Session
SESSION_NAME=_session
SESSION_LIFETIME=7200

# WhatsApp (Fonnte)
FONNTE_TOKEN=

# Base URL (kosongkan untuk auto-detect dari $_SERVER)
APP_URL=
